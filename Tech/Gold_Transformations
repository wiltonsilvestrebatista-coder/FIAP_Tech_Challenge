    .alias("realizado")
    .join(
        meta_municipio_longo.alias("meta"),
        (F.col("realizado.id_municipio") == F.col("meta.id_municipio"))
        & (F.col("realizado.ano") == F.col("meta.ano_meta"))
        & (F.col("realizado.rede") == F.col("meta.rede")),
        "left"
    )
    .select(
        F.col("realizado.ano").alias("ano"),
        F.col("realizado.id_municipio").alias("id_municipio"),
        F.col("realizado.id_municipio_nome").alias("id_municipio_nome"),
        F.col("realizado.taxa_alfabetizacao").alias("taxa_realizada"),
        F.col("meta.meta_taxa_alfabetizacao").alias("meta_taxa_alfabetizacao"),
        (F.col("realizado.taxa_alfabetizacao") - F.col("meta.meta_taxa_alfabetizacao")).alias("gap_meta"),
        F.col("realizado.origem").alias("origem"),
    )
    .withColumn(
        "meta_atingida",
        F.when(F.col("gap_meta").isNull(), F.lit(None))
         .when(F.col("gap_meta") >= 0, F.lit(True))
         .otherwise(F.lit(False))
    )
)

(
    gold_metas_vs_resultado.write
    .format("delta")
    .mode("overwrite")
    .saveAsTable("bd_alfabetizacao_gold.default.metas_vs_resultado_municipio")
)

print(f"OK: {gold_metas_vs_resultado.count()} linhas gravadas")



