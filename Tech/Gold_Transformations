from pyspark.sql import functions as F

def validar_nulos(df, colunas, nome_tabela=""):
    total = df.count()
    resultado = df.select([
        F.sum(F.col(c).isNull().cast("int")).alias(c) for c in colunas
    ]).collect()[0].asDict()

    print(f"--- Validação de nulos: {nome_tabela} (total de linhas: {total}) ---")
    problemas = False
    for coluna, qtd_nulos in resultado.items():
        pct = (qtd_nulos / total * 100) if total > 0 else 0
        status = "⚠️ ATENÇÃO" if qtd_nulos > 0 else "OK"
        print(f"{status} | {coluna}: {qtd_nulos} nulos ({pct:.2f}%)")
        if qtd_nulos > 0:
            problemas = True

    if not problemas:
        print("Nenhum nulo encontrado.")
    return resultado


