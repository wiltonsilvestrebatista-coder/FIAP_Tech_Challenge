indicador_uf_silver_completo = spark.table("bd_alfabetizacao_silver.default.indicador_alfabetizacao_uf")

evolucao_temporal_uf = (
    indicador_uf_silver_completo
    .groupBy("ano", "sigla_uf", "sigla_uf_nome", "rede")
    .agg(
        F.avg("taxa_alfabetizacao").alias("taxa_alfabetizacao_media"),
        F.avg("media_portugues").alias("media_portugues_media")
    )
)

evolucao_temporal_nacional = (
    indicador_uf_silver_completo
    .groupBy("ano", "rede")
    .agg(
        F.avg("taxa_alfabetizacao").alias("taxa_alfabetizacao_media"),
        F.avg("media_portugues").alias("media_portugues_media")
    )
    .withColumn("sigla_uf", F.lit("BR"))
    .withColumn("sigla_uf_nome", F.lit("Brasil"))
)

evolucao_temporal_gold = evolucao_temporal_uf.unionByName(evolucao_temporal_nacional)

(
    evolucao_temporal_gold.write
    .format("delta")
    .mode("overwrite")
    .saveAsTable("bd_alfabetizacao_gold.default.evolucao_temporal_indicador")
)

print(f"OK: {evolucao_temporal_gold.count()} linhas gravadas")
