from pyspark.sql import functions as F

def decode_column(df, id_tabela, coluna):
    """
    Decodifica uma coluna de código usando a base Bronze.
    Mantendo a coluna original como 'coluna_codigo' e adiciona
    a descrição decodificada na coluna.
    """
    lookup = (
        dicionario
        .filter((F.col("id_tabela") == id_tabela) & (F.col("nome_coluna") == coluna))
        .select(
            F.col("chave").alias("_chave_lookup"),
            F.col("valor").alias(coluna)
        )
    )
    return (
        df.withColumnRenamed(coluna, f"{coluna}_codigo")
        .join(
            lookup,
            F.col(f"{coluna}_codigo") == F.col("_chave_lookup"),
            "left"
        )
        .drop("_chave_lookup")
)
