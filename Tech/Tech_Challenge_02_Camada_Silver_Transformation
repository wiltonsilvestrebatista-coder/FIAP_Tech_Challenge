def validar_duplicidade(df, chave, nome_tabela=""):
    """
    Verifica se a combinação de colunas em chave é única.
    Retorna as linhas duplicadas.
    """
    total = df.count()
    duplicados = (
        df.groupBy(*chave)
        .count()
        .filter(F.col("count") > 1)
    )
    qtd_duplicados = duplicados.count()

    print(f"--- Validação de duplicidade: {nome_tabela} (chave: {chave}) ---")
    if qtd_duplicados == 0:
        print(f"OK | Nenhuma duplicidade encontrada em {total} linhas.")
    else:
        print(f"⚠️ ATENÇÃO | {qtd_duplicados} combinações de chave duplicadas encontradas.")
        display(duplicados)
    return duplicados


